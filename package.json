{
  "name": "fvtt-ts-template",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "prettier -w .",
    "lint": "npm-run-all --print-name -c lint:scripts lint:styles",
    "lint:scripts": "eslint .",
    "lint:styles": "stylelint **/*.{css,scss}",
    "typecheck": "tsc -b",
    "createSymlinks": "node ./tools/create-symlinks.mjs",
    "postinstall": "npm run createSymlinks"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.19.17",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.5.0",
    "eslint-plugin-tsdoc": "^0.4.0",
    "fvtt-types": "https://github.com/League-of-Foundry-Developers/foundry-vtt-types.git#commit=25260a80b97d6f6bec0d0f3df908a74e0657491b",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "run-s": "^0.0.0",
    "sass-embedded": "^1.99.0",
    "stylelint": "^16.26.1",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-scss": "^6.14.0",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.1",
    "vite-plugin-checker": "^0.8.0",
    "vite-plugin-static-copy": "^2.3.2",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "resolutions": {
    "meow": "^9.0.0"
  }
}